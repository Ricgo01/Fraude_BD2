<%- include('../partials/header', { title }) %>
<%- include('../partials/navbar', { title, role }) %>

<div class="layout">
    <%- include('../partials/sidebar', { role }) %>
    <main class="content">
        <div class="page-header">
            <h1>Detalle de Solicitud</h1>
            <p>Revision, documentos y resolucion de la solicitud.</p>
        </div>

        <div id="message"></div>

        <section class="section">
            <h2>Resumen</h2>
            <div class="grid-2">
                <div class="card">
                    <h3>Solicitud</h3>
                    <strong id="solicitud-id">-</strong>
                    <small id="solicitud-estado">-</small>
                </div>
                <div class="card">
                    <h3>Monto solicitado</h3>
                    <strong id="solicitud-monto">Q0</strong>
                    <small id="solicitud-fecha">-</small>
                </div>
            </div>
            <div class="grid-2">
                <div class="section" id="detalle-estudiante">
                    <h3>Estudiante</h3>
                    <p>Cargando...</p>
                </div>
                <div class="section" id="detalle-beca">
                    <h3>Beca</h3>
                    <p>Cargando...</p>
                </div>
            </div>
        </section>

        <section class="section">
            <div class="actions" style="justify-content: space-between;">
                <div>
                    <h2>Documentos</h2>
                    <p>Revisar y aprobar documentos adjuntos.</p>
                </div>
                <button class="btn btn-secondary" onclick="cargarDetalle()">Actualizar</button>
            </div>
            <div class="table-wrapper">
                <table class="table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Tipo</th>
                            <th>Valido</th>
                            <th>Estado revision</th>
                            <th>Accion</th>
                        </tr>
                    </thead>
                    <tbody id="documentos-table">
                        <tr><td colspan="5">Cargando...</td></tr>
                    </tbody>
                </table>
            </div>
        </section>

        <section class="section">
            <h2>Alertas</h2>
            <div class="table-wrapper">
                <table class="table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Tipo</th>
                            <th>Nivel</th>
                            <th>Resuelta</th>
                        </tr>
                    </thead>
                    <tbody id="alertas-table">
                        <tr><td colspan="4">Cargando...</td></tr>
                    </tbody>
                </table>
            </div>
        </section>

        <section class="section">
            <h2>Resolver solicitud</h2>
            <div class="grid-2">
                <div>
                    <label>Decision</label>
                    <select class="form-control" id="decision">
                        <option value="Aprobada">Aprobar</option>
                        <option value="Rechazada">Rechazar</option>
                    </select>
                </div>
                <div>
                    <label>Nota</label>
                    <input class="form-control" id="nota" placeholder="Observaciones">
                </div>
            </div>
            <button class="btn btn-primary" onclick="resolverSolicitud()">Guardar decision</button>
        </section>
    </main>
</div>

<script>
    window.solicitudId = '<%= solicitudId %>'
</script>

<%- include('../partials/footer', { pageScript: '/js/pages/reviewer-request-detail.js' }) %>