<%- include('../partials/header', { title }) %>
<%- include('../partials/navbar', { title, role }) %>

<div class="layout">
    <%- include('../partials/sidebar', { role }) %>
    <main class="content">
        <!-- Panel Superior (Banderas Rojas) -->
        <div id="banner-alertas" class="alert-banner" style="display: none; background-color: #f87171; color: white; padding: 15px; border-radius: 8px; margin-bottom: 20px; font-weight: bold; text-align: center; font-size: 1.1em;">
            <!-- Contenido dinámico desde JS -->
        </div>

        <div class="page-header">
            <h1>Sala de Analisis</h1>
            <p>Evaluacion de solicitud <span id="solicitud-id-header"></span></p>
        </div>

        <div id="message"></div>

        <div class="grid-3">
            <!-- Panel Izquierdo (Datos) -->
            <div class="card" style="grid-column: span 1;">
                <h2>Panel de Datos</h2>
                <div id="detalle-estudiante" style="margin-bottom: 15px;">
                    <h3>Estudiante</h3>
                    <p>Cargando...</p>
                </div>
                <div id="detalle-beca" style="margin-bottom: 15px;">
                    <h3>Beca Solicitada</h3>
                    <p>Cargando...</p>
                </div>
                <div id="detalle-solicitud">
                    <h3>Detalles de la Solicitud</h3>
                    <p>Cargando...</p>
                </div>
            </div>

            <!-- Panel Central (Auditoria de Documentos) -->
            <div class="card" style="grid-column: span 1;">
                <h2>Auditoria de Documentos</h2>
                <p><small>Marca los checkboxes para definir si son Validos o Invalidos y guarda la revision.</small></p>
                <div id="documentos-container" style="margin-top: 15px; margin-bottom: 20px;">
                    <p>Cargando...</p>
                </div>
                <button class="btn btn-secondary" style="width: 100%; margin-bottom: 10px;" onclick="marcarDocumentos()">Guardar Revision de Documentos</button>
            </div>

            <!-- Panel Derecho (Veredicto Final) -->
            <div class="card" style="grid-column: span 1;">
                <h2>Veredicto Final</h2>
                <div style="margin-bottom: 15px;">
                    <label style="font-weight: bold; display: block; margin-bottom: 5px;">Nota / Justificacion</label>
                    <textarea class="form-control" id="nota-veredicto" rows="4" placeholder="Escribe tu analisis y justificacion de la decision..." style="width: 100%; resize: vertical;"></textarea>
                    <button class="btn btn-secondary" style="width: 100%; margin-top: 10px;" onclick="guardarNotaRevision()">Agregar Nota</button>
                </div>
                
                <hr style="margin: 20px 0; border: 0; border-top: 1px solid #e5e7eb;">

                <p style="text-align: center; margin-bottom: 15px; font-weight: bold;">Toma de Decision</p>
                <div id="seccion-veredicto">
                    <!-- Botones o mensaje de resuelta, cargados por JS -->
                    <p style="color: #6b7280; text-align: center; font-size: 0.9em;">Cargando estado...</p>
                </div>
            </div>
        </div>
    </main>
</div>

<script>
    window.solicitudId = '<%= solicitudId %>'
</script>

<%- include('../partials/footer', { pageScript: '/js/pages/reviewer-request-detail.js' }) %>