<%- include('../partials/header', { title }) %>
<%- include('../partials/navbar', { title, role }) %>

<div class="layout">
    <%- include('../partials/sidebar', { role }) %>
    <main class="content">
        <div class="page-header">
            <h1>Dashboard de Trabajo</h1>
            <p>Resumen de tu actividad. Usa el menú lateral para gestionar tus casos.</p>
        </div>

        <div id="message"></div>

        <!-- KPI Cards -->
        <div class="grid-3" style="margin-bottom: 30px;">
            <div class="card" style="text-align: center; background: linear-gradient(135deg, #1e3a5f, #2563eb); color: white;">
                <p style="font-size: 0.85em; opacity: 0.8; margin-bottom: 5px;">📋 Disponibles</p>
                <p id="kpi-disponibles" style="font-size: 2.5em; font-weight: 800; margin: 0;">-</p>
                <p style="font-size: 0.75em; opacity: 0.7; margin-top: 4px;">Sin revisor asignado</p>
            </div>
            <div class="card" style="text-align: center; background: linear-gradient(135deg, #065f46, #10b981); color: white;">
                <p style="font-size: 0.85em; opacity: 0.8; margin-bottom: 5px;">🎯 Mis Casos</p>
                <p id="kpi-mis-casos" style="font-size: 2.5em; font-weight: 800; margin: 0;">-</p>
                <p style="font-size: 0.75em; opacity: 0.7; margin-top: 4px;">Pendientes de revisión</p>
            </div>
            <div class="card" style="text-align: center; background: linear-gradient(135deg, #7f1d1d, #ef4444); color: white;">
                <p style="font-size: 0.85em; opacity: 0.8; margin-bottom: 5px;">🚨 Alto Riesgo</p>
                <p id="kpi-alto-riesgo" style="font-size: 2.5em; font-weight: 800; margin: 0;">-</p>
                <p style="font-size: 0.75em; opacity: 0.7; margin-top: 4px;">Requieren atención urgente</p>
            </div>
        </div>

        <!-- Casos urgentes -->
        <section class="section">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <div>
                    <h2>🔥 Casos Urgentes (Alto Riesgo)</h2>
                    <p style="color: #6b7280; font-size: 0.9em;">Máximo 5 solicitudes con alertas de nivel alto.</p>
                </div>
                <a href="/revisor/mis-casos" class="btn btn-secondary">Ver todos mis casos →</a>
            </div>
            <div class="table-wrapper" style="margin-top: 15px;">
                <table class="table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Estudiante</th>
                            <th>Beca</th>
                            <th>Monto</th>
                            <th>Estado</th>
                            <th>Acción</th>
                        </tr>
                    </thead>
                    <tbody id="urgentes-table">
                        <tr><td colspan="6">Cargando...</td></tr>
                    </tbody>
                </table>
            </div>
        </section>

        <!-- Acciones rápidas -->
        <section class="section">
            <h2>Acciones Rápidas</h2>
            <div style="display: flex; gap: 15px; flex-wrap: wrap; margin-top: 10px;">
                <a href="/revisor/disponibles" class="btn btn-primary">📋 Ver Solicitudes Disponibles</a>
                <a href="/revisor/mis-casos" class="btn btn-secondary">🎯 Ir a Mis Casos</a>
                <a href="/revisor/historial" class="btn btn-secondary">📁 Ver Historial</a>
            </div>
        </section>
    </main>
</div>

<%- include('../partials/footer', { pageScript: '/js/pages/reviewer-dashboard.js' }) %>