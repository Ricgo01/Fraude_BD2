<%- include('../partials/header', { title }) %>
<%- include('../partials/navbar', { title, role }) %>

<div class="layout">
    <%- include('../partials/sidebar', { role }) %>

    <main class="content">
        <section class="hero-admin">
            <h1>Dashboard de Trabajo</h1>
            <p>Mi Bandeja de Entrada - Linea de Ensamblaje</p>
        </section>

        <div id="message"></div>

        <!-- Seccion A: Solicitudes Disponibles -->
        <section class="section">
            <div class="actions" style="justify-content: space-between;">
                <div>
                    <h2>Solicitudes Disponibles</h2>
                    <p>Piscina de solicitudes que nadie ha tomado.</p>
                </div>
                <button class="btn btn-secondary" onclick="cargarDisponibles()">Refrescar</button>
            </div>

            <div class="table-wrapper">
                <table class="table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Estudiante</th>
                            <th>Beca</th>
                            <th>Monto</th>
                            <th>Fecha</th>
                            <th>Accion</th>
                        </tr>
                    </thead>
                    <tbody id="disponibles-table">
                        <tr><td colspan="6">Cargando...</td></tr>
                    </tbody>
                </table>
            </div>
        </section>

        <!-- Seccion B: Mis Casos Pendientes -->
        <section class="section">
            <div class="actions" style="justify-content: space-between;">
                <div>
                    <h2>Mis Casos Pendientes</h2>
                    <p>Solicitudes asignadas a mi cola de revision.</p>
                </div>
                <div class="actions">
                    <label>Filtro por Nivel de Riesgo:</label>
                    <select class="form-control" id="riesgo-filter" onchange="cargarPendientes()">
                        <option value="">Todos</option>
                        <option value="bajo">Bajo</option>
                        <option value="medio">Medio</option>
                        <option value="alto">Alto</option>
                    </select>
                    <button class="btn btn-secondary" onclick="cargarPendientes()">Refrescar</button>
                </div>
            </div>

            <div class="table-wrapper">
                <table class="table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Estudiante</th>
                            <th>Beca</th>
                            <th>Monto</th>
                            <th>Estado</th>
                            <th>Riesgo</th>
                            <th>Accion</th>
                        </tr>
                    </thead>
                    <tbody id="pendientes-table">
                        <tr><td colspan="7">Cargando...</td></tr>
                    </tbody>
                </table>
            </div>
        </section>
    </main>
</div>

<%- include('../partials/footer', { pageScript: '/js/pages/reviewer-dashboard.js' }) %>