<%- include('../partials/header', { title }) %>
<%- include('../partials/navbar', { title, role }) %>

<div class="layout">
  <%- include('../partials/sidebar', { role }) %>
  <main class="content">
    <div class="page-header">
      <h1>Referencia</h1>
      <p>Agrega una referencia personal para tu solicitud.</p>
    </div>

    <div id="message"></div>

    <section class="section">
      <form id="referencia-form" class="grid-2">
        <div>
          <label>Nombre</label>
          <input class="form-control" id="nombre" required>
        </div>

        <div>
          <label>Telefono</label>
          <input class="form-control" id="telefono" required>
        </div>

        <div>
          <label>Relacion</label>
          <input class="form-control" id="relacion" placeholder="Padre, Madre" required>
        </div>

        <div>
          <label>Verificada</label>
          <select class="form-control" id="verificada">
            <option value="true">Si</option>
            <option value="false">No</option>
          </select>
        </div>

        <div>
          <label>Tipo aval</label>
          <input class="form-control" id="tipoAval" placeholder="Familiar, Laboral" required>
        </div>
      </form>

      <button class="btn btn-primary" onclick="guardarReferencia()">Guardar referencia</button>
    </section>

    <section class="section">
      <div class="actions" style="justify-content: space-between;">
        <div>
          <h2>Referencias registradas</h2>
          <p>Selecciona una referencia para editarla.</p>
        </div>
        <div class="actions">
          <select class="form-control" id="referencia-select" style="max-width: 280px;">
            <option value="">Selecciona una referencia</option>
          </select>
          <button class="btn btn-secondary" onclick="seleccionarReferencia()">Cargar</button>
          <button class="btn btn-primary" onclick="actualizarReferencia()">Actualizar referencia</button>
        </div>
      </div>

      <div class="table-wrapper">
        <table class="table">
          <thead>
            <tr>
              <th>Nombre</th>
              <th>Telefono</th>
              <th>Relacion</th>
              <th>Verificada</th>
            </tr>
          </thead>
          <tbody id="referencias-table">
            <tr><td colspan="4">Cargando...</td></tr>
          </tbody>
        </table>
      </div>
    </section>
  </main>
</div>

<%- include('../partials/footer', { pageScript: '/js/pages/estudiante-referencia.js' }) %>
