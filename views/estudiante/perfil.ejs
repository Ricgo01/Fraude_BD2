<%- include('../partials/header', { title }) %>
<%- include('../partials/navbar', { title, role }) %>

<div class="layout">
  <%- include('../partials/sidebar', { role }) %>

  <main class="content">
    <div class="page-header">
      <h1>Mi Perfil</h1>
      <p>Datos generales del estudiante y accesos rapidos.</p>
    </div>

    <div id="message"></div>

    <section class="section">
      <h2>Datos principales</h2>
      <div class="grid-2" id="perfil-info">
        <div class="card">
          <h3>Nombre</h3>
          <strong id="perfil-nombre">-</strong>
          <small id="perfil-email">-</small>
        </div>
        <div class="card">
          <h3>Promedio académico</h3>
          <strong id="perfil-promedio" style="font-size:1.8em;">0</strong>
          <small id="perfil-estado">-</small>
        </div>
        <div class="card">
          <h3>Fecha de nacimiento</h3>
          <strong id="perfil-nacimiento">-</strong>
        </div>
        <div class="card">
          <h3>Fecha de registro</h3>
          <strong id="perfil-fecha">-</strong>
        </div>
      </div>
    </section>

    <section class="section">
      <h2>Accesos rapidos</h2>
      <div class="grid-2">
        <a class="card link-card" href="/estudiante/cuenta">
          <h3>Cuenta bancaria</h3>
          <p>Registrar o actualizar datos de cuenta.</p>
        </a>
        <a class="card link-card" href="/estudiante/direccion">
          <h3>Direccion</h3>
          <p>Actualizar informacion de residencia.</p>
        </a>
        <a class="card link-card" href="/estudiante/institucion">
          <h3>Institucion</h3>
          <p>Vincula tu institucion educativa.</p>
        </a>
        <a class="card link-card" href="/estudiante/referencia">
          <h3>Referencia</h3>
          <p>Agrega referencias personales.</p>
        </a>
      </div>
    </section>
  </main>
</div>

<%- include('../partials/footer', { pageScript: '/js/pages/estudiante-perfil.js' }) %>