<%- include('../partials/head', { title }) %>
<%- include('../partials/navbar', { title, role }) %>

<div class="layout">
  <%- include('../partials/sidebar', { role }) %>

  <main class="content">
    <div class="page-header">
      <h1>Mi Perfil</h1>
      <p>Consulta y actualiza la información principal del estudiante.</p>
    </div>

    <div id="message"></div>

    <section class="section">
      <form id="perfil-form">
        <div class="grid-2">
          <div>
            <label>Nombre completo</label>
            <input class="form-control" name="nombre" id="nombre" required>
          </div>

          <div>
            <label>Promedio</label>
            <input class="form-control" name="promedio" id="promedio" type="number" step="0.01" required>
          </div>

          <div>
            <label>Institución</label>
            <input class="form-control" name="institucion" id="institucion" required>
          </div>

          <div>
            <label>Dirección</label>
            <input class="form-control" name="direccion" id="direccion" required>
          </div>

          <div>
            <label>Municipio</label>
            <input class="form-control" name="municipio" id="municipio" required>
          </div>

          <div>
            <label>Departamento</label>
            <input class="form-control" name="departamento" id="departamento" required>
          </div>
        </div>

        <button class="btn btn-primary" type="submit">
          Guardar cambios
        </button>
      </form>
    </section>

    <div class="grid-2">
      <section class="section">
        <h2>Cuenta bancaria</h2>
        <p id="cuenta-info">Cargando...</p>
      </section>

      <section class="section">
        <h2>Referencia</h2>
        <p id="referencia-info">Cargando...</p>
      </section>
    </div>
  </main>
</div>

<%- include('../partials/footer', { pageScript: '/js/pages/estudiante-perfil.js' }) %>