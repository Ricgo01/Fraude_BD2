<%- include('../partials/header', { title }) %>
<%- include('../partials/navbar', { title, role }) %>

<div class="layout">
  <%- include('../partials/sidebar', { role }) %>

  <main class="content">
    <div class="page-header">
      <h1>Nueva Solicitud</h1>
      <p>Registra una nueva solicitud de beca.</p>
    </div>

    <div id="message"></div>

    <section class="section">
      <form id="solicitud-form" class="grid-2">
        <div>
          <label>Motivo de apoyo</label>
          <textarea class="form-control" id="motivo" rows="4" required></textarea>
        </div>

        <div>
          <label>Monto solicitado</label>
          <input class="form-control" type="number" id="monto" required>
        </div>

        <div>
          <label>Apoyo total</label>
          <select class="form-control" id="apoyoTotal">
            <option value="true">Si</option>
            <option value="false">No</option>
          </select>
        </div>

        <div>
          <label>Beca</label>
          <select class="form-control" id="becaId" required>
            <option value="">Selecciona una beca</option>
          </select>
        </div>
      </form>

      <button class="btn btn-primary" onclick="crearSolicitud()">Crear solicitud</button>
    </section>
  </main>
</div>

<%- include('../partials/footer', { pageScript: '/js/pages/estudiante-nueva-solicitud.js' }) %>