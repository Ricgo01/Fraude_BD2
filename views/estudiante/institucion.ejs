<%- include('../partials/header', { title }) %>
<%- include('../partials/navbar', { title, role }) %>

<div class="layout">
  <%- include('../partials/sidebar', { role }) %>
  <main class="content">
    <div class="page-header">
      <h1>Institucion</h1>
      <p>Vincula tu institucion educativa con tu perfil.</p>
    </div>

    <div id="message"></div>

    <section class="section">
      <form id="institucion-form" class="grid-2">
        <div>
          <label>Nombre</label>
          <input class="form-control" id="nombre" required>
        </div>

        <div>
          <label>Tipo</label>
          <input class="form-control" id="tipo" placeholder="Universidad, Colegio" required>
        </div>

        <div>
          <label>Departamento</label>
          <input class="form-control" id="departamento" required>
        </div>

        <div>
          <label>Publica</label>
          <select class="form-control" id="publica">
            <option value="true">Si</option>
            <option value="false">No</option>
          </select>
        </div>

        <div>
          <label>Fecha convenio</label>
          <input class="form-control" id="fechaConvenio" type="date" required>
        </div>

        <div>
          <label>Desde fecha</label>
          <input class="form-control" id="desdeFecha" type="date" required>
        </div>

        <div>
          <label>Carrera</label>
          <input class="form-control" id="carrera" required>
        </div>

        <div>
          <label>Estado academico</label>
          <input class="form-control" id="estadoAcademico" placeholder="Activo" required>
        </div>
      </form>

      <button class="btn btn-primary" onclick="guardarInstitucion()">Guardar institucion</button>
    </section>
  </main>
</div>

<%- include('../partials/footer', { pageScript: '/js/pages/estudiante-institucion.js' }) %>
