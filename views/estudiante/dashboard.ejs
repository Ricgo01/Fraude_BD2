<%- include('../partials/header', { title }) %>
<%- include('../partials/navbar', { title, role }) %>

<div class="layout">
  <%- include('../partials/sidebar', { role }) %>

  <main class="content">
    <section class="hero-admin">
      <h1>Portal del Estudiante</h1>
      <p>Consulta tu perfil, revisa tus solicitudes y da seguimiento a tus documentos.</p>
    </section>

    <div id="message"></div>

    <section class="cards">
      <div class="card">
        <h3>Solicitudes totales</h3>
        <strong id="total-solicitudes">0</strong>
      </div>

      <div class="card">
        <h3>Pendientes</h3>
        <strong id="solicitudes-pendientes">0</strong>
      </div>

      <div class="card">
        <h3>Aprobadas</h3>
        <strong id="solicitudes-aprobadas">0</strong>
      </div>

      <div class="card">
        <h3>Documentos</h3>
        <strong id="total-documentos">0</strong>
      </div>
    </section>

    <section class="section">
      <h2>Últimas solicitudes</h2>
      <p>Resumen de tus solicitudes más recientes.</p>

      <div class="table-wrapper">
        <table class="table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Monto</th>
              <th>Estado</th>
              <th>Fecha</th>
              <th>Accion</th>
            </tr>
          </thead>
          <tbody id="solicitudes-table">
            <tr><td colspan="6">Cargando...</td></tr>
          </tbody>
        </table>
      </div>
    </section>
  </main>
</div>

<%- include('../partials/footer', { pageScript: '/js/pages/estudiante-dashboard.js' }) %>