<%- include('../partials/header', { title }) %>
<%- include('../partials/navbar', { title, role }) %>

<div class="layout">
  <%- include('../partials/sidebar', { role }) %>

  <main class="content">
    <div class="page-header">
      <h1>Detalle de Solicitud</h1>
      <p>Consulta la informacion principal de tu solicitud.</p>
    </div>

    <div id="message"></div>

    <section class="cards">
      <div class="card">
        <h3>Solicitud</h3>
        <strong id="solicitud-id">-</strong>
      </div>

      <div class="card">
        <h3>Estado</h3>
        <strong id="solicitud-estado">-</strong>
      </div>

      <div class="card">
        <h3>Monto</h3>
        <strong id="solicitud-monto">Q0</strong>
      </div>

      <div class="card">
        <h3>Apoyo total</h3>
        <strong id="solicitud-apoyo">-</strong>
      </div>
    </section>

    <section class="section">
      <h2>Detalles</h2>
      <p id="solicitud-info">Cargando...</p>
      <a class="btn btn-secondary" href="/estudiante/documentos">Ver documentos</a>
    </section>
  </main>
</div>

<script>
  window.solicitudId = '<%= solicitudId %>'
</script>

<%- include('../partials/footer', { pageScript: '/js/pages/estudiante-detalle-solicitud.js' }) %>