<%- include('../partials/header', { title }) %>
<%- include('../partials/navbar', { title, role }) %>

<div class="layout">
  <%- include('../partials/sidebar', { role }) %>
  <main class="content">
    <div class="page-header">
      <h1>Dispositivo</h1>
      <p>Registra el dispositivo utilizado para ingresar al sistema.</p>
    </div>

    <div id="message"></div>

    <section class="section">
      <form id="dispositivo-form" class="grid-2">
        <div>
          <label>Navegador</label>
          <input class="form-control" id="navegador" placeholder="Chrome, Edge" required>
        </div>

        <div>
          <label>Sistema operativo</label>
          <input class="form-control" id="sistema" placeholder="Windows, macOS" required>
        </div>
      </form>

      <button class="btn btn-primary" onclick="guardarDispositivo()">Guardar dispositivo</button>
    </section>

    <section class="section">
      <div class="actions" style="justify-content: space-between;">
        <div>
          <h2>Dispositivos registrados</h2>
          <p>Selecciona un dispositivo para editarlo.</p>
        </div>
        <div class="actions">
          <select class="form-control" id="dispositivo-select" style="max-width: 280px;">
            <option value="">Selecciona un dispositivo</option>
          </select>
          <button class="btn btn-secondary" onclick="seleccionarDispositivo()">Cargar</button>
          <button class="btn btn-primary" onclick="actualizarDispositivo()">Actualizar dispositivo</button>
        </div>
      </div>

      <div class="table-wrapper">
        <table class="table">
          <thead>
            <tr>
              <th>Navegador</th>
              <th>Sistema operativo</th>
              <th>Activo</th>
            </tr>
          </thead>
          <tbody id="dispositivos-table">
            <tr><td colspan="3">Cargando...</td></tr>
          </tbody>
        </table>
      </div>
    </section>
  </main>
</div>

<%- include('../partials/footer', { pageScript: '/js/pages/estudiante-dispositivo.js' }) %>
