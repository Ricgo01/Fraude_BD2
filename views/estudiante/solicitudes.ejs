<%- include('../partials/header', { title }) %>
<%- include('../partials/navbar', { title, role }) %>

<div class="layout">
  <%- include('../partials/sidebar', { role }) %>

  <main class="content">
    <div class="page-header">
      <h1>Mis Solicitudes</h1>
      <p>Consulta tus solicitudes y filtra por estado.</p>
    </div>

    <div id="message"></div>

    <section class="section">
      <div class="actions" style="justify-content: space-between;">
        <div>
          <label>Filtrar por estado</label>
          <select id="estado-filter" class="form-control" style="width: 240px;">
            <option value="">Todas</option>
            <option value="Pendiente">Pendiente</option>
            <option value="Aprobada">Aprobada</option>
            <option value="Rechazada">Rechazada</option>
          </select>
        </div>

        <a class="btn btn-primary" href="/estudiante/solicitudes/nueva">
          Nueva solicitud
        </a>
      </div>

      <div class="table-wrapper">
        <table class="table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Monto</th>
              <th>Estado</th>
              <th>Fecha</th>
              <th>Accion</th>
            </tr>
          </thead>
          <tbody id="solicitudes-table">
            <tr><td colspan="5">Cargando...</td></tr>
          </tbody>
        </table>
      </div>
    </section>
  </main>
</div>

<%- include('../partials/footer', { pageScript: '/js/pages/estudiante-solicitudes.js' }) %>