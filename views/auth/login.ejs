<%- include('../partials/header', { title: 'Login', bodyClass: 'auth-body' }) %>

<main class="auth-layout">
  <section class="auth-card">
    <div class="auth-header">
      <h1>Ingreso al sistema</h1>
      <p>Accede con tu correo registrado para entrar al portal.</p>
    </div>

    <div id="message"></div>

    <form id="login-form" class="auth-form">
      <label>Correo electronico</label>
      <input class="form-control" type="email" id="email" placeholder="correo@ejemplo.com" required>

      <button type="submit" class="btn btn-primary">Ingresar</button>
    </form>

    <p class="auth-footer">
      No tienes cuenta?
      <a href="/registro">Crear registro</a>
    </p>
  </section>
</main>

<%- include('../partials/footer', { pageScript: '/js/pages/login.js' }) %>