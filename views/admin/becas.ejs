<%- include('../partials/header', { title }) %>
<%- include('../partials/navbar', { title, role }) %>

<div class="layout">
  <%- include('../partials/sidebar', { role }) %>
  <main class="content">
    <div class="page-header">
      <h1>Gestion de Becas</h1>
      <p>Crea programas y revisa estadisticas de solicitudes por beca.</p>
    </div>

    <div id="message"></div>

    <section class="section">
      <h2>Nueva beca</h2>
      <form id="beca-form" class="grid-2">
        <div>
          <label>Nombre de la beca</label>
          <input class="form-control" id="nombreBeca" required>
        </div>

        <div>
          <label>Categoria</label>
          <select class="form-control" id="categoria" required>
            <option value="Excelencia Académica">Excelencia Académica</option>
            <option value="Necesidad Económica">Necesidad Económica</option>
            <option value="Deportiva">Deportiva</option>
            <option value="Investigación">Investigación</option>
            <option value="Técnica">Técnica</option>
          </select>
        </div>

        <div>
          <label>Monto maximo</label>
          <input class="form-control" id="montoMax" type="number" required>
        </div>

        <div>
          <label>Renovable</label>
          <select class="form-control" id="renovable">
            <option value="true">Si</option>
            <option value="false">No</option>
          </select>
        </div>

        <div>
          <label>Fecha de inicio</label>
          <input class="form-control" id="fechaInicio" type="date" required>
        </div>
      </form>

      <button class="btn btn-primary" onclick="crearBeca()">Crear beca</button>
    </section>

    <section class="section">
      <div class="actions" style="justify-content: space-between;">
        <div>
          <h2>Estadisticas por beca</h2>
          <p>Promedio, minimo y maximo de montos solicitados.</p>
        </div>
        <button class="btn btn-secondary" onclick="cargarBecasStats()">Actualizar</button>
      </div>

      <div class="table-wrapper">
        <table class="table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Nombre</th>
              <th>Categoria</th>
              <th>Solicitudes</th>
              <th>Promedio</th>
              <th>Minimo</th>
              <th>Maximo</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody id="becas-table">
            <tr><td colspan="8">Cargando...</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Modal Editar Beca -->
    <div id="modal-editar-beca" class="modal" style="display: none;">
      <div class="modal-content" style="max-width: 500px;">
        <div class="modal-header">
          <h2>Editar Beca</h2>
          <button class="close-btn" onclick="cerrarModalEditarBeca()">×</button>
        </div>
        <div class="modal-body">
          <form id="edit-beca-form" class="grid-2">
            <input type="hidden" id="editBecaId">
            <div style="grid-column: span 2;">
              <label>Nombre de la beca</label>
              <input class="form-control" id="editNombreBeca" required>
            </div>
            <div>
              <label>Categoria</label>
              <select class="form-control" id="editCategoria" required>
                <option value="Excelencia Académica">Excelencia Académica</option>
                <option value="Necesidad Económica">Necesidad Económica</option>
                <option value="Deportiva">Deportiva</option>
                <option value="Investigación">Investigación</option>
                <option value="Técnica">Técnica</option>
              </select>
            </div>
            <div>
              <label>Monto maximo</label>
              <input class="form-control" id="editMontoMax" type="number" required>
            </div>
            <div>
              <label>Renovable</label>
              <select class="form-control" id="editRenovable">
                <option value="true">Si</option>
                <option value="false">No</option>
              </select>
            </div>
          </form>
        </div>
        <div class="modal-footer" style="margin-top: 20px; display: flex; justify-content: flex-end; gap: 10px;">
          <button class="btn btn-secondary" onclick="cerrarModalEditarBeca()">Cancelar</button>
          <button class="btn btn-primary" onclick="guardarBeca()">Guardar Cambios</button>
        </div>
      </div>
    </div>

    <section class="section">
      <h2>Filtrar estudiantes por promedio</h2>
      <div class="actions">
        <select class="form-control" id="becaFiltroId" style="max-width: 260px;">
          <option value="">Selecciona una beca</option>
        </select>
        <button class="btn btn-secondary" onclick="filtrarEstudiantes()">Buscar</button>
      </div>

      <div class="table-wrapper">
        <table class="table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Nombre</th>
              <th>Email</th>
              <th>Promedio</th>
            </tr>
          </thead>
          <tbody id="estudiantes-table">
            <tr><td colspan="4">Selecciona una beca.</td></tr>
          </tbody>
        </table>
      </div>
    </section>
  </main>
</div>

<%- include('../partials/footer', { pageScript: '/js/pages/admin-becas.js' }) %>