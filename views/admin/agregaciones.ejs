<%- include('../partials/header', { title }) %>
<%- include('../partials/navbar', { title, role }) %>

<div class="layout">
  <%- include('../partials/sidebar', { role }) %>
  <main class="content">
    <div class="page-header">
      <h1>Agregaciones y Gestion</h1>
      <p>Resumenes, filtros y acciones administrativas sobre datos y relaciones.</p>
    </div>

    <div id="message"></div>

    <section class="section">
      <div class="actions" style="justify-content: space-between;">
        <div>
          <h2>Resumen general</h2>
          <p>Agregaciones consolidadas del grafo.</p>
        </div>
        <button class="btn btn-secondary" onclick="cargarAgregaciones()">Actualizar</button>
      </div>

      <div class="grid-2">
        <div class="card">
          <h3>Max puntaje riesgo</h3>
          <strong id="max-riesgo">0</strong>
        </div>
        <div class="card">
          <h3>Min promedio</h3>
          <strong id="min-promedio">0</strong>
        </div>
        <div class="card">
          <h3>Depositos</h3>
          <strong id="sum-depositos">Q0</strong>
        </div>
        <div class="card">
          <h3>Documentos relacionados</h3>
          <strong id="doc-rel">0</strong>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="actions" style="justify-content: space-between;">
        <div>
          <h2>Solicitudes por estado</h2>
          <p>Distribucion de solicitudes registradas.</p>
        </div>
        <button class="btn btn-secondary" onclick="cargarSolicitudesEstados()">Actualizar</button>
      </div>

      <div class="table-wrapper" style="max-height: 400px; overflow-y: auto;">
        <table class="table">
          <thead>
            <tr>
              <th>Estado</th>
              <th>Total</th>
            </tr>
          </thead>
          <tbody id="solicitudes-estado-table">
            <tr><td colspan="2">Cargando...</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="section">
      <h2>Pendientes por revisor</h2>
      <div class="actions">
        <select class="form-control" id="pendiente-revisor-id" style="max-width: 240px;">
          <option value="">Selecciona un revisor</option>
        </select>
        <button class="btn btn-secondary" onclick="cargarPendientesRevisor()">Buscar</button>
      </div>

      <div class="table-wrapper" style="max-height: 400px; overflow-y: auto;">
        <table class="table">
          <thead>
            <tr>
              <th>Solicitud</th>
              <th>Estudiante</th>
              <th>Monto</th>
              <th>Fecha</th>
              <th>Estado</th>
            </tr>
          </thead>
          <tbody id="pendientes-revisor-table">
            <tr><td colspan="5">Selecciona un revisor.</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="section">
      <div class="actions" style="justify-content: space-between;">
        <div>
          <h2>Estadisticas de cuentas</h2>
          <p>Conteo de estudiantes por cuenta.</p>
        </div>
        <button class="btn btn-secondary" onclick="cargarCuentasStats()">Actualizar</button>
      </div>

      <div class="table-wrapper" style="max-height: 400px; overflow-y: auto;">
        <table class="table">
          <thead>
            <tr>
              <th>ID Cuenta</th>
              <th>Banco</th>
              <th>Estudiantes</th>
              <th>Compartida</th>
            </tr>
          </thead>
          <tbody id="cuentas-table">
            <tr><td colspan="4">Cargando...</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <div class="grid-2">
      <section class="section">
        <div class="actions" style="justify-content: space-between;">
          <div>
            <h2>Documentos invalidos</h2>
            <p>Documentos con flag invalido.</p>
          </div>
          <button class="btn btn-secondary" onclick="cargarDocumentosInvalidos()">Actualizar</button>
        </div>
        <div class="table-wrapper" style="max-height: 400px; overflow-y: auto;">
          <table class="table">
            <thead>
              <tr>
                <th>ID</th>
                <th>Tipo</th>
                <th>Fecha</th>
              </tr>
            </thead>
            <tbody id="documentos-invalidos-table">
              <tr><td colspan="3">Cargando...</td></tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="section">
        <div class="actions" style="justify-content: space-between;">
          <div>
            <h2>Pagos fallidos</h2>
            <p>Pagos con multiples intentos.</p>
          </div>
          <button class="btn btn-secondary" onclick="cargarPagosFallidos()">Actualizar</button>
        </div>
        <div class="table-wrapper" style="max-height: 400px; overflow-y: auto;">
          <table class="table">
            <thead>
              <tr>
                <th>ID</th>
                <th>Monto</th>
                <th>Intentos</th>
              </tr>
            </thead>
            <tbody id="pagos-fallidos-table">
              <tr><td colspan="3">Cargando...</td></tr>
            </tbody>
          </table>
        </div>
      </section>
    </div>

  </main>
</div>

<%- include('../partials/footer', { pageScript: '/js/pages/admin-agregaciones.js' }) %>
