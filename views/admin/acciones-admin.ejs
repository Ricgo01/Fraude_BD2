<%- include('../partials/header', { title }) %>
<%- include('../partials/navbar', { title, role }) %>

<div class="layout">
  <%- include('../partials/sidebar', { role }) %>
  <main class="content">
    <div class="page-header">
      <h1>Acciones Admin</h1>
      <p>Operaciones administrativas sobre alertas, solicitudes y usuarios del sistema.</p>
    </div>

    <div id="message"></div>

    <section class="section">
      <div class="tabs">
        <button class="tab-btn active" onclick="openTab('tab-investigacion', event)">Investigación</button>
        <button class="tab-btn" onclick="openTab('tab-disciplinarias', event)">Acciones disciplinarias</button>
        <button class="tab-btn" onclick="openTab('tab-correcciones', event)">Correcciones</button>
        <button class="tab-btn" onclick="openTab('tab-mantenimiento', event)">Mantenimiento</button>
      </div>

      <!-- TAB: INVESTIGACIÓN -->
      <div id="tab-investigacion" class="tab-content" style="display: block; margin-top: 20px;">
        <p class="tab-subtitle">Acciones para documentar hallazgos durante la investigación de casos sospechosos.</p>
        <div class="grid-2">

          <!-- Agregar nota de investigación -->
          <div class="form-card">
            <h3>Agregar nota de investigación</h3>
            <p class="form-card-desc">Registra hallazgos o contexto en una alerta específica. Si ya tiene una nota, la nueva la reemplazará.</p>
            <select class="form-control" id="obs-alerta-id" onchange="previsualizarAlertaNota()">
              <option value="">Selecciona una alerta de la lista</option>
            </select>
            <div id="obs-alerta-preview" class="preview-box" style="display:none;"></div>
            <textarea class="form-control" id="obs-alerta-texto" rows="4" placeholder="Describe el hallazgo o contexto relevante de esta alerta..." style="margin-top:10px;"></textarea>
            <button class="btn btn-secondary" onclick="agregarObservacion()">Guardar nota</button>
          </div>

          <!-- Cambiar nivel de gravedad -->
          <div class="form-card">
            <h3>Cambiar nivel de gravedad</h3>
            <p class="form-card-desc">Sube o baja el nivel de una alerta según la evidencia recolectada. El nuevo nivel reemplaza al actual.</p>
            <select class="form-control" id="riesgo-alerta-id" onchange="previsualizarAlertaNivel()">
              <option value="">Selecciona una alerta de la lista</option>
            </select>
            <div id="riesgo-alerta-preview" class="preview-box" style="display:none;"></div>
            <select class="form-control" id="riesgo-alerta-nivel" style="margin-top:10px;">
              <option value="">Selecciona el nuevo nivel</option>
              <option value="bajo">Bajo</option>
              <option value="medio">Medio</option>
              <option value="alto">Alto</option>
            </select>
            <button class="btn btn-secondary" onclick="actualizarNivelRiesgo()">Actualizar nivel</button>
          </div>

          <!-- Marcar solicitudes como auditadas -->
          <div class="form-card">
            <h3>Marcar solicitudes como auditadas</h3>
            <p class="form-card-desc">Deja constancia de que estas solicitudes ya fueron revisadas internamente. No cambia el estado oficial.</p>
            <input type="text" class="form-control" id="filtro-solicitudes-auditar" placeholder="Buscar por nombre de estudiante..." onkeyup="filtrarSolicitudesAuditar()" style="margin-bottom: 8px;">
            <div id="auditar-solicitudes-list" class="checkbox-list" style="max-height: 200px; overflow-y: auto; margin-bottom: 10px;"></div>
            <button class="btn btn-secondary" onclick="auditarSolicitudes()">Marcar como auditadas</button>
          </div>

          <!-- Verificar documentos adjuntos -->
          <div class="form-card">
            <h3>Verificar documentos adjuntos</h3>
            <p class="form-card-desc">Confirma que los documentos de una solicitud fueron verificados manualmente. Marca las relaciones de adjunto como auditadas.</p>
            <div id="auditar-adjuntas-list" class="checkbox-list" style="max-height: 200px; overflow-y: auto; margin-bottom: 10px;"></div>
            <button class="btn btn-secondary" onclick="auditarAdjuntas()">Verificar documentos</button>
          </div>

        </div>
      </div>

      <!-- TAB: ACCIONES DISCIPLINARIAS -->
      <div id="tab-disciplinarias" class="tab-content" style="display: none; margin-top: 20px;">
        <p class="tab-subtitle">Medidas contra usuarios o casos confirmados como fraudulentos o sospechosos.</p>
        <div class="grid-2">

          <!-- Bloquear estudiantes sospechosos -->
          <div class="form-card">
            <h3>Bloquear estudiantes sospechosos</h3>
            <p class="form-card-desc">Desactiva múltiples estudiantes detectados en una red de fraude. Los bloqueados no podrán hacer nuevas solicitudes.</p>
            <input type="text" class="form-control" id="filtro-estudiantes-admin" placeholder="Buscar por nombre..." onkeyup="filtrarEstudiantesAdmin()" style="margin-bottom: 8px;">
            <div id="desactivar-estudiantes-list" class="checkbox-list" style="max-height: 220px; overflow-y: auto; margin-bottom: 10px;"></div>
            <button class="btn btn-danger" onclick="desactivarEstudiantesConfirm()">Bloquear seleccionados</button>
          </div>

          <!-- Cambiar estado de alertas en lote -->
          <div class="form-card">
            <h3>Cambiar estado de alertas en lote</h3>
            <p class="form-card-desc">Actualiza el estado de varias alertas al mismo tiempo. Útil al iniciar o cerrar operativos de auditoría.</p>
            <div id="estado-alerta-ids-list" class="checkbox-list" style="max-height: 200px; overflow-y: auto; margin-bottom: 10px;"></div>
            <select class="form-control" id="estado-alerta">
              <option value="">Selecciona un estado</option>
              <option value="activa">Activa</option>
              <option value="en_revision">En revisión</option>
              <option value="resuelta">Resuelta</option>
            </select>
            <button class="btn btn-secondary" onclick="actualizarEstadoAlertas()" style="margin-top:10px;">Actualizar estado</button>
          </div>

        </div>
      </div>

      <!-- TAB: CORRECCIONES -->
      <div id="tab-correcciones" class="tab-content" style="display: none; margin-top: 20px;">
        <p class="tab-subtitle">Deshacer o corregir acciones previas que fueron incorrectas o ya no aplican.</p>
        <div class="grid-2">

          <!-- Borrar nota de un revisor -->
          <div class="form-card">
            <h3>Borrar nota de un revisor</h3>
            <p class="form-card-desc">Elimina la nota que un revisor agregó a una solicitud. Al seleccionar, se muestra el contenido actual de la nota.</p>
            <select class="form-control" id="nota-solicitud-id" onchange="previsualizarNota()">
              <option value="">Selecciona una solicitud con nota</option>
            </select>
            <div id="nota-preview" class="preview-box" style="display:none;"></div>
            <button class="btn btn-danger" id="btn-borrar-nota" onclick="eliminarNotaRevisionConfirm()" disabled style="margin-top:10px;">Borrar nota</button>
          </div>

          <!-- Quitar verificación de documentos -->
          <div class="form-card">
            <h3>Quitar verificación de documentos</h3>
            <p class="form-card-desc">Revierte la auditoría de documentos cuando una verificación previa fue incorrecta y debe rehacerse.</p>
            <div id="desauditar-adjuntas-list" class="checkbox-list" style="max-height: 200px; overflow-y: auto; margin-bottom: 10px;"></div>
            <button class="btn btn-secondary" onclick="desauditarAdjuntas()">Quitar verificación</button>
          </div>

          <!-- Descartar alerta individual -->
          <div class="form-card">
            <h3>Descartar alerta individual</h3>
            <p class="form-card-desc">Elimina una alerta confirmada como falso positivo junto con todas sus relaciones. Acción irreversible.</p>
            <select class="form-control" id="alerta-eliminar-id" onchange="previsualizarAlertaDetalle()">
              <option value="">Selecciona una alerta de la lista</option>
            </select>
            <div id="alerta-eliminar-preview" class="preview-box" style="display:none;"></div>
            <button class="btn btn-danger" onclick="eliminarAlertaConfirm()" style="margin-top:10px;">Descartar alerta</button>
          </div>

          <!-- Desvincular alerta de solicitud -->
          <div class="form-card">
            <h3>Desvincular alerta de solicitud</h3>
            <p class="form-card-desc">Quita la conexión entre una alerta y su solicitud sin eliminar la alerta. Útil cuando la alerta fue mal asociada.</p>
            <div id="relaciones-alerta-list" class="checkbox-list" style="max-height: 200px; overflow-y: auto; margin-bottom: 10px;"></div>
            <button class="btn btn-danger" onclick="eliminarRelacionesAlertasConfirm()">Desvincular seleccionadas</button>
          </div>

        </div>
      </div>

      <!-- TAB: MANTENIMIENTO -->
      <div id="tab-mantenimiento" class="tab-content" style="display: none; margin-top: 20px;">
        <p class="tab-subtitle">Limpieza periódica de datos antiguos, resueltos o sensibles.</p>
        <div class="grid-2">

          <!-- Limpiar alertas cerradas -->
          <div class="form-card">
            <h3>Limpiar alertas cerradas</h3>
            <p class="form-card-desc">Elimina en lote alertas que ya fueron marcadas como resueltas. Sirve para limpiar la base al final de un periodo.</p>
            <div id="alertas-resueltas-list" class="checkbox-list" style="max-height: 200px; overflow-y: auto; margin-bottom: 10px;"></div>
            <button class="btn btn-danger" onclick="eliminarAlertasResueltasConfirm()">Eliminar seleccionadas</button>
          </div>

          <!-- Limpiar notas de alertas resueltas -->
          <div class="form-card">
            <h3>Limpiar notas de alertas resueltas</h3>
            <p class="form-card-desc">Elimina las observaciones internas de alertas que ya fueron resueltas. Las notas ya no son necesarias una vez cerrado el caso.</p>
            <div id="alertas-campo-list" class="checkbox-list" style="max-height: 200px; overflow-y: auto; margin-bottom: 10px;"></div>
            <button class="btn btn-danger" onclick="eliminarCampoAlertasConfirm()">Limpiar notas</button>
          </div>

          <!-- Borrar IP por privacidad -->
          <div class="form-card">
            <h3>Borrar IP por privacidad</h3>
            <p class="form-card-desc">Elimina el hash de IP de un dispositivo verificado. Se hace por privacidad una vez confirmado que no es sospechoso.</p>
            <select class="form-control" id="dispositivo-id" onchange="previsualizarDispositivo()">
              <option value="">Selecciona un dispositivo de la lista</option>
            </select>
            <div id="dispositivo-preview" class="preview-box" style="display:none;"></div>
            <button class="btn btn-danger" onclick="eliminarIPHashConfirm()" style="margin-top:10px;">Borrar IP</button>
          </div>

        </div>
      </div>
    </section>
  </main>
</div>

<style>
.tabs {
  display: flex;
  gap: 6px;
  border-bottom: 2px solid #e5e7eb;
  padding-bottom: 0;
  flex-wrap: wrap;
}
.tab-btn {
  background: none;
  border: none;
  border-bottom: 3px solid transparent;
  padding: 10px 18px;
  cursor: pointer;
  font-weight: 600;
  font-size: 0.9em;
  color: #6B7280;
  margin-bottom: -2px;
  transition: color 0.15s, border-color 0.15s;
  border-radius: 6px 6px 0 0;
}
.tab-btn:hover { color: #374151; background: #f9fafb; }
.tab-btn.active { color: #2563eb; border-bottom-color: #2563eb; background: none; }
.tab-subtitle {
  font-size: 0.9em;
  color: #6b7280;
  margin: 0 0 20px 0;
  padding-bottom: 12px;
  border-bottom: 1px solid #f3f4f6;
}
.form-card-desc {
  font-size: 0.85em;
  color: #6b7280;
  margin: 0 0 14px 0;
  line-height: 1.5;
}
.checkbox-list {
  border: 1px solid #e5e7eb;
  border-radius: 6px;
  padding: 10px;
  background: #f9fafb;
}
.preview-box {
  margin: 10px 0 0 0;
  padding: 12px;
  background: #f0f7ff;
  border-left: 4px solid #3b82f6;
  border-radius: 4px;
  font-size: 0.875em;
  line-height: 1.6;
}
.preview-box p { margin: 2px 0; }
.preview-box .preview-label { font-weight: 600; color: #1e40af; }
.preview-nota-texto {
  margin: 6px 0 0 0;
  padding: 8px 12px;
  background: white;
  border-left: 3px solid #9ca3af;
  font-style: italic;
  color: #4b5563;
  border-radius: 2px;
}
.preview-aviso {
  margin-top: 8px;
  font-size: 0.8em;
  color: #dc2626;
}
</style>

<script>
function openTab(tabId, event) {
  document.querySelectorAll('.tab-content').forEach(el => el.style.display = 'none');
  document.querySelectorAll('.tab-btn').forEach(el => el.classList.remove('active'));
  document.getElementById(tabId).style.display = 'block';
  if (event && event.target) event.target.classList.add('active');
}
</script>

<%- include('../partials/footer', { pageScript: '/js/pages/admin-acciones-admin.js' }) %>
