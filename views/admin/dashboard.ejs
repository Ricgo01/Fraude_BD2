<%- include('../partials/header', { title }) %>
<%- include('../partials/navbar', { title, role }) %>

<div class="layout">
  <%- include('../partials/sidebar', { role }) %>

  <main class="content">
    <section class="hero-admin">
      <h1>Dashboard Administrativo</h1>
      <p>Panel de Control Aereo - Metricas globales y riesgo rapido.</p>
    </section>

    <div id="message"></div>

    <!-- Metricas Globales -->
    <section class="cards" style="margin-bottom: 30px;">
      <div class="card">
        <h3>Total Alertas</h3>
        <strong id="total-alertas" style="color: #ef4444;">0</strong>
        <small>Alertas registradas</small>
      </div>

      <div class="card">
        <h3>Pendientes</h3>
        <strong id="alertas-pendientes" style="color: #f59e0b;">0</strong>
        <small>Alertas sin resolver</small>
      </div>

      <div class="card">
        <h3>Cuentas Compartidas</h3>
        <strong id="cuentas-compartidas">0</strong>
        <small>Posibles casos de riesgo</small>
      </div>

      <div class="card">
        <h3>Riesgo Promedio</h3>
        <strong id="riesgo-promedio">0</strong>
        <small>Puntaje consolidado</small>
      </div>
    </section>

    <!-- Filtros de Riesgo Rapido -->
    <div class="grid-2">
      <!-- Tabla 1: Estudiantes con Promedios Bajos -->
      <section class="section" style="grid-column: span 1;">
        <div class="actions" style="justify-content: space-between; align-items: flex-end;">
          <div>
            <h2>Promedios Sospechosos</h2>
            <p><small>Estudiantes con promedios bajos.</small></p>
          </div>
          <div style="display: flex; gap: 5px;">
            <select id="beca-id-select" class="form-control" style="width: 150px;">
              <option value="">Cargando becas...</option>
            </select>
            <button class="btn btn-secondary" onclick="cargarPromediosBajos()">Ver</button>
          </div>
        </div>
        <div class="table-wrapper" style="max-height: 400px; overflow-y: auto;">
          <table class="table">
            <thead>
              <tr>
                <th>ID</th>
                <th>Estudiante</th>
                <th>Promedio</th>
              </tr>
            </thead>
            <tbody id="promedios-table">
              <tr><td colspan="3">Ingresa un ID de beca y presiona Ver.</td></tr>
            </tbody>
          </table>
        </div>
      </section>

      <!-- Tabla 2: Pagos Fallidos en Bucle -->
      <section class="section" style="grid-column: span 1;">
        <div class="actions" style="justify-content: space-between;">
          <div>
            <h2>Pagos Fallidos</h2>
            <p><small>Posibles intentos de fraude en pagos.</small></p>
          </div>
          <button class="btn btn-secondary" onclick="cargarPagosFallidos()">Actualizar</button>
        </div>
        <div class="table-wrapper" style="max-height: 400px; overflow-y: auto;">
          <table class="table">
            <thead>
              <tr>
                <th>Estudiante ID</th>
                <th>Nombre</th>
                <th>Fallos</th>
              </tr>
            </thead>
            <tbody id="pagos-table">
              <tr><td colspan="3">Cargando...</td></tr>
            </tbody>
          </table>
        </div>
      </section>
    </div>
  </main>
</div>

<%- include('../partials/footer', { pageScript: '/js/pages/admin-dashboard.js' }) %>