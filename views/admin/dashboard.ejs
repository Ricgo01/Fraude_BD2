<%- include('../partials/head', { title }) %>
<%- include('../partials/navbar', { title, role }) %>

<div class="layout">
  <%- include('../partials/sidebar', { role }) %>

  <main class="content">
    <div class="page-header">
      <h1>Dashboard Administrativo</h1>
      <p>Resumen general de alertas, cuentas, becas y riesgos detectados.</p>
    </div>

    <div id="message"></div>

    <section class="cards">
      <div class="card">
        <h3>Total alertas</h3>
        <strong id="total-alertas">0</strong>
      </div>

      <div class="card">
        <h3>Alertas pendientes</h3>
        <strong id="alertas-pendientes">0</strong>
      </div>

      <div class="card">
        <h3>Cuentas compartidas</h3>
        <strong id="cuentas-compartidas">0</strong>
      </div>

      <div class="card">
        <h3>Riesgo promedio</h3>
        <strong id="riesgo-promedio">0</strong>
      </div>
    </section>

    <section class="section">
      <h2>Alertas pendientes recientes</h2>
      <p>Alertas automáticas generadas por el sistema y pendientes de resolución.</p>

      <table class="table">
        <thead>
          <tr>
            <th>ID alerta</th>
            <th>Tipo</th>
            <th>Nivel</th>
            <th>Puntaje</th>
            <th>Solicitud</th>
            <th>Fecha</th>
          </tr>
        </thead>
        <tbody id="alerts-table">
          <tr>
            <td colspan="6">Cargando datos...</td>
          </tr>
        </tbody>
      </table>
    </section>

    <section class="section">
      <h2>Acciones rápidas</h2>
      <button class="btn btn-primary" onclick="ejecutarDeteccion()">
        Ejecutar detección automática
      </button>

      <a href="/admin/alertas" class="btn btn-secondary">
        Ver alertas
      </a>

      <a href="/admin/fraude" class="btn btn-secondary">
        Ver reportes de fraude
      </a>
    </section>
  </main>
</div>

<script src="/js/pages/admin-dashboard.js"></script>

<%- include('../partials/footer') %>